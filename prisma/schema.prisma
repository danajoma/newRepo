generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model admins {
  id               Int           @id
  experience_years Int?
  users            users         @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  interns          interns[]
  projects         projects[]
  supervisors      supervisors[]
}

model feedbacks {
  id            Int          @id @default(autoincrement())
  task_id       Int?
  intern_id     Int?
  supervisor_id Int?
  comment       String?
  rating        Int?
  date          DateTime?    @db.Date
  interns       interns?     @relation(fields: [intern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  supervisors   supervisors? @relation(fields: [supervisor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tasks         tasks?       @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model interns {
  id               Int         @id
  admin_id         Int?
  university       String?     @db.VarChar(100)
  major            String?     @db.VarChar(100)
  attendance_ratio Int?
  feedbacks        feedbacks[]
  admins           admins?     @relation(fields: [admin_id], references: [id], onUpdate: NoAction)
  users            users       @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tasks            tasks[]
}

model projects {
  id                  Int          @id @default(autoincrement())
  created_by_admin_id Int?
  supervisor_id       Int?
  title               String?      @db.VarChar(100)
  description         String?
  start_date          DateTime?    @db.Date
  end_date            DateTime?    @db.Date
  admins              admins?      @relation(fields: [created_by_admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  supervisors         supervisors? @relation(fields: [supervisor_id], references: [id], onUpdate: NoAction)
  tasks               tasks[]
}

model supervisors {
  id        Int         @id
  admin_id  Int?
  company   String?     @db.VarChar(100)
  feedbacks feedbacks[]
  projects  projects[]
  admins    admins?     @relation(fields: [admin_id], references: [id], onUpdate: NoAction)
  users     users       @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model tasks {
  id          Int         @id @default(autoincrement())
  project_id  Int?
  intern_id   Int?
  title       String?     @db.VarChar(100)
  description String?
  status      String?     @db.VarChar(50)
  deadline    DateTime?   @db.Date
  feedbacks   feedbacks[]
  interns     interns?    @relation(fields: [intern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects    projects?   @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id          Int          @id @default(autoincrement())
  name        String?      @db.VarChar(100)
  email       String?      @unique @db.VarChar(100)
  password    String?      @db.VarChar(255)
  role        String?      @db.VarChar(50)
  admins      admins?
  interns     interns?
  supervisors supervisors?
}
